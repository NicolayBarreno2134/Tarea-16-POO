<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: #e8f5e9;" stylesheets="@login.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto16.proyecto16.LoginController">

    <VBox alignment="CENTER" spacing="15" style="-fx-background-color: #E0FFEC; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

        <Label fx:id="tituloLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" text="Iniciar sesión" />
        <Label style="-fx-text-fill: #555;" text="Ingresa tus credenciales para continuar" />

        <Label text="Usuario" />
        <TextField fx:id="usuarioTextField" promptText="Ingrese su usuario" />

        <Label text="Contraseña" />
        <PasswordField fx:id="contraseñaTextField" promptText="Ingrese su contraseña" />

        <Label text="Rol" />
        <ComboBox fx:id="rolComboBox" promptText="Seleccione un rol" />

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="ingresarButton" onAction="#ingresar" text="Ingresar" />
            <Button fx:id="cancelarButton" onAction="#salir" text="Cancelar" />
        </HBox>

        <Label style="-fx-font-size: 10px; -fx-text-fill: #777;" text="Sistema v1.0 © 2026 Tu Empresa" />
    </VBox>
</StackPane>
